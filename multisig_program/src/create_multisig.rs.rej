--- multisig_program/src/create_multisig.rs
+++ multisig_program/src/create_multisig.rs
@@ -1,5 +1,8 @@
 // CreateMultisig handler — initializes a new M-of-N multisig
 
+use nssa_core::program::env;
+use nssa_core::account::AccountWithMetadata;
+
 pub fn handle(
     accounts: &[AccountWithMetadata],
     create_key: &[u8; 32],
@@ -7,6 +10,11 @@ pub fn handle(
     members: &[[u8; 32]],
 ) -> (Vec<Account>, Vec<ChainedCall>) {
+    let self_id = env::program_id();
+    let pid_hex: String = self_id.iter().flat_map(|w| w.to_le_bytes()).map(|b| format!({:02x}, b)).collect();
+    let key_hex = hex::encode(create_key);
+    env::eprintln(&format!(GUEST: program_id={} create_key={}, pid_hex, key_hex));
+
     // Validate inputs
     assert!(!members.is_empty(), Multisig must have at least one member);
 
 
